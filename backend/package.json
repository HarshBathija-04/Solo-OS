    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "pg": "^8.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
