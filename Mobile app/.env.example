# ─────────────────────────────────────────────────────────────
# SOLO OS — Environment Configuration (TEMPLATE)
# Copy this file to `.env` and fill in your values.
# The app RUNS WITHOUT an API URL configured (local-only demo mode),
# but full progression sync requires pointing it to your deployed website.
#
# ⚠️  DO NOT put real secrets in this file — it is a shareable template.
#     Put real values in `.env` (which is git-ignored).
# ─────────────────────────────────────────────────────────────

# ── Shared backend (the Next.js website REST API) ──
# This is the canonical backend. Point it at your running website.
#   • Local dev on a simulator:   http://localhost:3000
#   • Physical device on Wi-Fi:   http://<your-computer-LAN-IP>:3000
#   • Production:                 https://your-website-url.vercel.app
# When unset, the app runs local-only (no login, no cross-device sync).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# AI Provider (OPTIONAL — app works fully without any key via MockAIProvider)
# Supported: mock | claude | openai | gemini
EXPO_PUBLIC_AI_PROVIDER=mock
